# =============================================================================
# smol-brain gateway configuration
# Copy to `.env` (loaded automatically) and adjust. All vars are prefixed
# GATEWAY_ to avoid clashing with the vLLM container's own environment.
# =============================================================================

# --- Service -----------------------------------------------------------------
GATEWAY_SERVICE_NAME=smol-brain-gateway
GATEWAY_ENVIRONMENT=production
GATEWAY_LOG_LEVEL=INFO

# --- vLLM upstream (internal cluster URL — keep off the public network) ------
GATEWAY_VLLM_BASE_URL=http://smol-brain:8000/v1
GATEWAY_VLLM_API_KEY=not-needed
GATEWAY_MODEL_NAME=Qwen/Qwen3.5-2B
GATEWAY_DEFAULT_TEMPERATURE=0.7
GATEWAY_DEFAULT_MAX_TOKENS=1024

# --- Upstream HTTP connection pool -------------------------------------------
GATEWAY_HTTP_MAX_CONNECTIONS=1000
GATEWAY_HTTP_MAX_KEEPALIVE_CONNECTIONS=200
GATEWAY_HTTP_CONNECT_TIMEOUT_S=5.0
GATEWAY_HTTP_READ_TIMEOUT_S=120.0

# --- Redis -------------------------------------------------------------------
GATEWAY_REDIS_URL=redis://redis:6379/0
GATEWAY_REDIS_MAX_CONNECTIONS=200
GATEWAY_REDIS_SOCKET_TIMEOUT_S=2.0

# --- Caching -----------------------------------------------------------------
GATEWAY_CACHE_ENABLED=true
GATEWAY_CACHE_TTL_S=3600
GATEWAY_SEMANTIC_CACHE_ENABLED=false
GATEWAY_SEMANTIC_CACHE_DISTANCE_THRESHOLD=0.1
GATEWAY_SEMANTIC_CACHE_TTL_S=3600
GATEWAY_EMBEDDINGS_BASE_URL=http://smol-brain:8000/v1
GATEWAY_EMBEDDINGS_API_KEY=not-needed
GATEWAY_EMBEDDINGS_MODEL=intfloat/e5-small-v2

# --- Rate limiting (token bucket, per API key/IP) ----------------------------
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_CAPACITY=120
GATEWAY_RATE_LIMIT_REFILL_PER_SECOND=2.0

# --- Resilience --------------------------------------------------------------
GATEWAY_RETRY_MAX_ATTEMPTS=3
GATEWAY_RETRY_INITIAL_BACKOFF_S=0.25
GATEWAY_RETRY_MAX_BACKOFF_S=4.0
GATEWAY_CIRCUIT_BREAKER_FAIL_MAX=5
GATEWAY_CIRCUIT_BREAKER_RESET_TIMEOUT_S=30.0

# --- Security ----------------------------------------------------------------
# Comma-separated list of accepted API keys. REQUIRED in production.
GATEWAY_API_KEYS=replace-with-a-strong-key,another-key
GATEWAY_API_KEY_HEADER=X-API-Key
# Comma-separated allowed CORS origins. Leave empty to lock down (no browser).
GATEWAY_CORS_ALLOW_ORIGINS=

# --- Gunicorn (read by gunicorn_conf.py) -------------------------------------
GATEWAY_BIND=0.0.0.0:8080
GATEWAY_WORKERS=
GATEWAY_WORKER_TIMEOUT=180
GATEWAY_GRACEFUL_TIMEOUT=30
