# =============================================================================
# smol-brain configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your setup:
#   cp .env.example .env
# Docker Compose automatically loads `.env` from this directory.
# =============================================================================

# --- Authentication ----------------------------------------------------------
# Hugging Face access token. Required for gated models like Llama 3.
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_token_here

# --- Model -------------------------------------------------------------------
# Any model on the Hugging Face Hub, e.g. Qwen/Qwen2.5-7B-Instruct
MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# --- Inference tuning --------------------------------------------------------
# Fraction of GPU memory vLLM may use (0.0 - 1.0). Lower if sharing the GPU.
GPU_MEMORY_UTILIZATION=0.90

# Maximum context window length. Lower this to save VRAM.
MAX_MODEL_LEN=4096

# Number of GPUs to split the model across (set to your GPU count).
TENSOR_PARALLEL_SIZE=1

# --- Hardware ----------------------------------------------------------------
# Number of GPUs to expose to the container. Use "all" or an integer (e.g. 2).
GPU_COUNT=all
