# =============================================================================
# smol-brain full stack configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your setup:
#   cp .env.example .env
# Docker Compose automatically loads `.env` from this directory.
# =============================================================================

# --- vLLM inference engine (GPU required) ------------------------------------
# Hugging Face access token. Required for gated models like Llama 3.
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_token_here

# Any model on the Hugging Face Hub, e.g. Qwen/Qwen2.5-7B-Instruct
MODEL=Qwen/Qwen3.5-2B

# Fraction of GPU memory vLLM may use (0.0 - 1.0). Lower if sharing the GPU.
GPU_MEMORY_UTILIZATION=0.75

# Maximum context window length. Lower this to save VRAM.
MAX_MODEL_LEN=4096

# Number of GPUs to split the model across (set to your GPU count).
TENSOR_PARALLEL_SIZE=1

# Number of GPUs to expose to the container. Use "all" or an integer (e.g. 2).
NVIDIA_VISIBLE_DEVICES=all

# --- Python gateway ----------------------------------------------------------
# API keys (comma-separated). REQUIRED in production.
GATEWAY_API_KEYS=replace-with-a-strong-key,another-key

# CORS origins (comma-separated). Leave empty to lock down.
GATEWAY_CORS_ALLOW_ORIGINS=

# Cache enabled
GATEWAY_CACHE_ENABLED=true

# Rate limiting
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_CAPACITY=120
GATEWAY_RATE_LIMIT_REFILL_PER_SECOND=2.0

# Gunicorn workers (auto = 2 * CPU + 1)
GATEWAY_WORKERS=
GATEWAY_WORKER_TIMEOUT=180

# --- Common settings for all gateways ----------------------------------------
# vLLM endpoint (internal network)
GATEWAY_VLLM_API_KEY=not-needed
GATEWAY_VLLM_BASE_URL=http://smol-brain:8000/v1

# Redis (shared)
GATEWAY_REDIS_URL=redis://redis:6379/0